# Prototype mode: demo library + leaderboard without Postgres (default when DATABASE_URL is empty)
# KINTSUGI_PROTOTYPE=true

# PostgreSQL (see docker-compose.yml — default port 5433)
DATABASE_URL="postgresql://kintsugi:kintsugi@localhost:5433/kintsugi"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth app (Authorization callback: http://localhost:3000/api/auth/callback/github)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Optional: OpenAI Auto-Doc
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
